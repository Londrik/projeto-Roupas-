<%- include('./includes/head.ejs') %>

<body>
    <%- include('./includes/navigation.ejs') %>

    <main class="container">
        <div class="order-confirmation-container">
            <div class="confirmation-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-check-circle"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <h1>Pedido Confirmado!</h1>
            <p class="subtitle">Obrigado pela sua compra, [Nome do Cliente]!</p>
            <p>Seu pedido <strong>#12345</strong> foi recebido e está sendo processado. Você receberá um email em breve com os detalhes do envio.</p>

            <div class="order-summary-card confirmation-summary">
                <h2>Resumo da Compra</h2>
                <div class="summary-items">
                    <% if (cart && cart.products && cart.products.length > 0) { %>
                        <% cart.products.forEach(p => { %>
                            <div class="summary-item">
                                <div class="summary-item-image">
                                    <img src="<%= p.item.imageUrl %>" alt="<%= p.item.name %>">
                                    <span class="summary-item-quantity"><%= p.quantity %></span>
                                </div>
                                <div class="summary-item-details">
                                    <p><%= p.item.name %></p>
                                    <small>Tamanho: <%= p.size %></small>
                                </div>
                                <div class="summary-item-price">
                                    <p>R$ <%= (parseFloat(p.item.price.replace('R$', '').replace(',', '.')) * p.quantity).toFixed(2).replace('.', ',') %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p>Não foi possível carregar os itens do seu pedido.</p>
                    <% } %>
                </div>
                <div class="summary-total">
                    <span>Total Pago</span>
                    <span>R$ <%= cart.totalPrice.toFixed(2).replace('.', ',') %></span>
                </div>
            </div>

            <a href="/products" class="banner-button">Continuar Comprando</a>
        </div>
    </main>

    <%- include('./includes/end.ejs') %>
</body>

</html>
