<!DOCTYPE html>
<html lang="pt-BR">

<%- include('includes/head.ejs') %>

<body>

    <%- include('includes/navigation.ejs') %>

    <main>
        <!-- NOVO BANNER PRINCIPAL COM IMAGEM DO PRODUTO REAL -->
        <section class="main-banner" style="background-image: url('/images/look-corset-branco.jpg');">
            <div class="main-banner__content">
                <h1>A estação da elegância.</h1>
                <a href="/products" class="banner-button">CONHEÇA A COLEÇÃO</a>
            </div>
        </section>

        <div class="container">
            <!-- SEÇÃO DE PRODUTOS EM DESTAQUE COM NOVO DESIGN -->
            <section class="featured-products-section">
                <h2>Lançamentos</h2>
                <div class="product-grid">
                    <% products.forEach(product => { %>
                        <% if (product.isFeatured) { %>
                            <div class="product-card">
                                <a href="/products/<%= product.id %>">
                                    <div class="product-image-container">
                                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                                    </div>
                                    <div class="product-info">
                                        <h3><%= product.name %></h3>
                                        <p class="product-price">R$ <%= product.price.toFixed(2).replace('.', ',') %></p>
                                        <span class="button-like">Ver Detalhes</span>
                                    </div>
                                </a>
                            </div>
                        <% } %>
                    <% }) %>
                </div>
            </section>
        </div>
    </main>
    
    <%- include('includes/end.ejs') %>
